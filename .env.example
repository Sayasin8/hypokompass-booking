# ============================================================
# HypoKompass Buchungssystem – Konfiguration
# Kopiere diese Datei zu .env und fülle die Werte aus
# ============================================================

# Server
PORT=3000
BASE_URL=https://buchen.hypokompass.de

# Admin-Passwort (bitte ändern!)
ADMIN_PASSWORD=DeinSicheresPasswort123!

# Apple iCloud CalDAV
# App-spezifisches Passwort erstellen unter: appleid.apple.com
CALDAV_URL=https://caldav.icloud.com
CALDAV_USERNAME=deine@icloud.com
CALDAV_PASSWORD=xxxx-xxxx-xxxx-xxxx
CALDAV_CALENDAR_NAME=HypoKompass Termine

# STRATO E-Mail (SMTP)
SMTP_HOST=smtp.strato.de
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=yasin.uca@hypokompass.de
SMTP_PASS=DeinSTRATOPasswort

# Buchungseinstellungen
SLOT_DURATION_MINUTES=60
BOOKING_START_HOUR=8
BOOKING_END_HOUR=18
BOOKING_DAYS=1,2,3,4,5
MAX_RESCHEDULE_COUNT=3
ADVANCE_BOOKING_DAYS=60
